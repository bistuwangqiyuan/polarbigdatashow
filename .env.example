# ============================================================
# 光伏故障 Vision API — 自动切换链路（按优先级从上到下）
# 只需填写你拥有 key 的提供方即可，无 key 则自动跳过
# ============================================================

# 1. Groq — Llama 4 Scout 多模态（免费额度）
GROQ_API_KEY=

# 2. Mistral — Pixtral 多模态
MISTRAL_API_KEY=

# 3. 智谱 AI — GLM-4V
GLM_API_KEY=

# 4. 阿里云灵积 DashScope — 通义千问 Qwen-VL
DASHSCOPE_API_KEY=
# 国际区域可设自定义兼容端点（默认 https://dashscope.aliyuncs.com/compatible-mode/v1）
# DASHSCOPE_COMPAT_BASE_URL=

# 5. Google Gemini
GEMINI_API_KEY=

# 6. OpenAI GPT-4o（最终兜底）
OPENAI_API_KEY=

